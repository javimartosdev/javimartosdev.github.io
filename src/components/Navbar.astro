---
import type { Locale, Translation } from '../i18n/types';
import LanguageToggle from './LanguageToggle.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  locale: Locale;
  t: Translation;
}

const { locale, t } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-[var(--border)] bg-[var(--bg)]/95 backdrop-blur no-print">
  <div class="mx-auto flex h-[60px] max-w-[950px] items-center justify-between px-6">
    <a href={`/${locale}/`} class="text-lg font-bold">
      JM<span class="text-[var(--accent)]">.</span>
    </a>
    <nav class="hidden items-center gap-4 text-sm font-medium sm:flex">
      <a href="#about" class="hover:text-[var(--accent)]">{t.nav.about}</a>
      <a href="#projects" class="hover:text-[var(--accent)]">{t.nav.projects}</a>
      <a href="#experience" class="hover:text-[var(--accent)]">{t.nav.experience}</a>
      <a href="#education" class="hover:text-[var(--accent)]">{t.nav.education}</a>
    </nav>
    <div class="flex items-center gap-2">
      <LanguageToggle locale={locale} labels={t.language} />
      <ThemeToggle lightLabel={t.theme.light} darkLabel={t.theme.dark} />
    </div>
  </div>
</header>
