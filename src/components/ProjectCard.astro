---
interface Props {
  title: string;
  description: string;
  github?: string;
  status?: string;
  stack: string[];
}

const { title, description, github, status, stack } = Astro.props;
---

<article class="mb-4 rounded-lg border border-[var(--border)] bg-[var(--bg)] p-4 transition-shadow hover:shadow-md">
  <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
    <h3 class="text-base font-bold">{title}</h3>
    <div class="flex items-center gap-2">
      {status && (
        <span class="rounded-full bg-[var(--secondary-bg)] px-2 py-0.5 text-xs font-semibold text-[var(--accent)]">
          {status}
        </span>
      )}
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-[var(--accent)] hover:underline"
          aria-label={`GitHub — ${title}`}
        >
          GitHub ↗
        </a>
      )}
    </div>
  </div>
  <p class="mb-3 text-sm text-[var(--muted)]">{description}</p>
  <div class="flex flex-wrap gap-1.5">
    {stack.map((tag) => (
      <span class="rounded border border-[var(--border)] bg-[var(--secondary-bg)] px-2 py-0.5 text-xs font-semibold">
        {tag}
      </span>
    ))}
  </div>
</article>
